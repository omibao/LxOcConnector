# ============================================================
# 蓝信 ↔ opencode 桥接服务配置
# 复制本文件为 .env 并填写真实值
# ============================================================

# ---- 蓝信个人机器人凭证 ----
# 获取方式：蓝信桌面端 → 通讯录 → 智能机器人 → 个人机器人 → 点击右侧 ℹ️ 图标
# （移动端不支持查看凭证）
LANSENGER_APP_ID=
LANSENGER_APP_SECRET=

# API 网关地址
#   公有云：https://open.e.lanxin.cn/open/apigw
#   私有部署：填贵司的网关地址（通常类似 https://open.xxx.com/open/apigw）
LANSENGER_API_GATEWAY_URL=https://open.e.lanxin.cn/open/apigw

# ---- opencode 服务端 ----
# 本机 opencode serve 的地址（运行 `opencode serve` 后默认 http://localhost:4096）
OPENCODE_BASE_URL=http://localhost:4096

# 如启动 opencode serve 时设置了 OPENCODE_SERVER_PASSWORD，则填这里
OPENCODE_SERVER_PASSWORD=

# opencode 使用的模型（providerID/modelID 格式，对应 opencode.json 配置）
# 留空则使用 opencode 的默认模型
OPENCODE_MODEL_PROVIDER=
OPENCODE_MODEL_ID=

# opencode 单次请求超时（秒，默认 600=10分钟；大会话上下文加载较慢）
OPENCODE_TIMEOUT=600

# 是否把 AI 的 thinking（思考过程）实时转发到蓝信
SEND_THINKING=true
# thinking 转发间隔（秒）：每隔多久把累积的思考内容发一条到蓝信
THINKING_FLUSH_INTERVAL=3

# ---- 桥接服务行为 ----
# 群聊是否要求 @机器人 才响应（true/false）
# 个人机器人私聊只有创建者本人可用；主战场是群聊 @提及
REQUIRE_MENTION=true

# 是否允许所有用户使用（true=开发调试用；false=仅 ALLOWED_USERS 中的用户）
ALLOW_ALL_USERS=false

# 允许使用的用户 ID 列表（逗号分隔）
# 当 ALLOW_ALL_USERS=false 时，此列表不能为空，否则启动将被拒绝（fail-closed）。
# 用户 ID 是蓝信内部 openId，首次发消息时会在日志里打印出来
ALLOWED_USERS=

# 每个蓝信会话是否独立对应一个 opencode session（true=保留上下文；false=每次新建）
# 推荐保留上下文，以便多轮对话
SESSION_PERSISTENCE=true

# 单条回复最大字符数（超出会自动分段发送）
MAX_MESSAGE_LENGTH=4000

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
